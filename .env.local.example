# Copy this file to .env.local and fill in your values

# ── AI ──────────────────────────────────────────────────────────
# Groq — fast LLaMA inference for Kundli readings
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# ── VEDIC ASTROLOGY ─────────────────────────────────────────────
# Prokerala — Kundli, Panchang, Muhurta, planetary positions
# Register free at: https://api.prokerala.com
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

# ── EMAIL MARKETING (Sender) ─────────────────────────────────────
# Sender.net — transactional email + subscriber/lead management
# Get your API key at: https://app.sender.net/settings/tokens
SENDER_API_KEY=

# The "from" address for outgoing emails
# Must be a verified sender in Sender.net (Settings > Senders)
SENDER_FROM_EMAIL=kundli@setu.app

# Sender Group ID — the subscriber group to tag as "Free Kundli Lead"
# Create a group at: https://app.sender.net/subscribers/groups → copy the ID
# Leave blank to add subscribers without a group
SENDER_GROUP_ID=

# Email to receive Contact Us form notifications
CONTACT_NOTIFY_EMAIL=haarsh.shahh@gmail.com
